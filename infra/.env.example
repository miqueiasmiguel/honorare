# Variáveis necessárias para o deploy.
#
# Em produção este arquivo é passado ao container do backend via `env_file`
# (docker-compose.yml) e usado pelo compose para substituir ${...} nos
# arquivos de override (docker-compose.prod.yml). Copie para `.env` e preencha.

# Senha do Postgres (usada pelo serviço postgres e na ConnectionString do backend)
POSTGRES_PASSWORD=

# Google OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Segredo de assinatura dos JWTs — mínimo 32 caracteres.
# Gere com: openssl rand -base64 48
# ATENÇÃO: alterar este valor invalida todos os access/refresh tokens emitidos.
Jwt__Secret=
